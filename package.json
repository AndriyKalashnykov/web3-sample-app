{
  "name": "web3-sample-app",
  "version": "v0.0.14",
  "private": true,
  "description": "Web3 frontend with React, Vite, TypeScript ane Ether.js",
  "license": "MIT",
  "author": "AndriyKalashnykov(AndriyKalashnykov@gmail.com)",
  "scripts": {
    "build": "tsc && vite build",
    "dev": "vite --host",
    "preview": "vite preview",
    "prettier": "prettier --ignore-path .gitignore --write 'src/**/*.{ts,tsx,js,jsx}'",
    "prettier:diff": "prettier -l 'src/**/*.{ts,tsx,js,jsx}'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@rematch/core": "^2.2.0",
    "axios": "^1.13.6",
    "ethers": "^6.16.0",
    "i18next": "^25.10.9",
    "i18next-http-backend": "^3.0.2",
    "mui": "^0.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.6.6",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.2",
    "jsdom": "29.0.1",
    "postcss": "8.5.8",
    "prettier": "3.8.1",
    "pretty-quick": "4.2.2",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "vite": "8.0.3",
    "vitest": "4.1.2"
  },
  "pnpm": {
    "overrides": {
      "svgo": "npm:@kingyue/svgo@^2.9.0",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3"
    }
  }
}
