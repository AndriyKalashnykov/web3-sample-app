{
  "name": "web3-sample-app",
  "version": "v0.0.14",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "description": "Web3 frontend with React, Vite, TypeScript and Ether.js",
  "license": "MIT",
  "author": "AndriyKalashnykov(AndriyKalashnykov@gmail.com)",
  "scripts": {
    "build": "tsc && vite build",
    "dev": "vite --host",
    "preview": "vite preview",
    "prettier": "prettier --ignore-path .gitignore --write 'src/**/*.{ts,tsx,js,jsx}'",
    "prettier:diff": "prettier -l 'src/**/*.{ts,tsx,js,jsx}'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:e2e:browser": "playwright test -c e2e/playwright.config.ts"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@reduxjs/toolkit": "^2.11.2",
    "viem": "^2.48.1",
    "i18next": "^26.0.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.4",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@playwright/test": "1.59.1",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.4",
    "jsdom": "29.0.2",
    "postcss": "8.5.10",
    "prettier": "3.8.3",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.3",
    "vite": "8.0.8",
    "vitest": "4.1.4"
  },
  "pnpm": {}
}
