{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":automergeDigest",
    ":automergePatch",
    ":automergeMinor",
    ":semanticCommits",
    ":separateMultipleMajorReleases",
    "schedule:nonOfficeHours"
  ],
  "labels": ["dependencies"],
  "prConcurrentLimit": 50,
  "automerge": true,
  "automergeType": "pr",
  "platformAutomerge": true,
  "ignoreTests": false,
  "rollbackPrs": true,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  },
  "packageRules": [
    {
      "description": "Automerge all non-major updates",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true
    },
    {
      "description": "Require manual merge for major updates",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "breaking"]
    },
    {
      "description": "Group all GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "automerge": true
    },
    {
      "description": "Group all devDependency non-major updates",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "dev-dependencies",
      "automerge": true
    },
    {
      "description": "Group all type definition updates",
      "matchPackageNames": ["/^@types//"],
      "groupName": "type-definitions",
      "automerge": true
    },
    {
      "description": "Pin TypeScript to 5.x (ecosystem not ready for 6.x)",
      "matchPackageNames": ["typescript"],
      "allowedVersions": "<6.0.0"
    }
  ]
}
