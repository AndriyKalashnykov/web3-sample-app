###
# Environment configuration for the SPA.
#
# Copy to `.env` (gitignored) and edit for your environment. The K8s ConfigMap
# at k8s/cm.yaml mirrors these for in-cluster runs; update both when changing
# defaults.
#
# Vite picks up `VITE_*` keys at build time AND at runtime via the
# start-nginx.sh envsubst pass against the bundled JS. Non-VITE keys are
# read by the container/runtime only (e.g. nginx, k8s probes).
###

# ---------------------------------------------------------------------------
# SPA / runtime
# ---------------------------------------------------------------------------

# Ethereum JSON-RPC endpoint queried by ethers.js. Override per chain.
VITE_RPCENDPOINT=https://ethereum-rpc.publicnode.com

# Base path used by the in-app /api proxy (currently the nginx /rpc location).
VITE_BASE_URL=/api/

# ---------------------------------------------------------------------------
# Container / cluster (mirrored in k8s manifests; change all together)
# ---------------------------------------------------------------------------

# nginx listen port inside the container. Changing this requires updating:
#   - nginx/nginx.conf  `listen` directive
#   - Dockerfile.prod   `EXPOSE`
#   - k8s/deployment.yaml  `containerPort` and `PORT` env
#   - k8s/service.yaml     `port` / `targetPort`
#   - k8s/kind-config.yaml `extraPortMappings.containerPort` (NodePort 30080)
PORT=8080
