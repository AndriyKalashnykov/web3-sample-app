###
# .env.example — committed source of truth for operator-tunable values.
#
# Copy to `.env` (gitignored) to override locally. Shell scripts source
# `.env.example` then `.env` (set -a); the Makefile mirrors these values as
# `?=` defaults; the SPA reads VITE_* at runtime via /config.js (Pattern C).
# Inline `${VAR:-default}` fallbacks in scripts mirror the values below so
# they still work if this file is absent.
#
# In production, start-caddy.sh runs envsubst over config.js.template at
# container start and writes /config.js; the K8s ConfigMap (k8s/cm.yaml)
# mirrors VITE_* / PORT for in-cluster runs — update both when changing them.
###

# ---------------------------------------------------------------------------
# SPA / runtime
# ---------------------------------------------------------------------------

# Ethereum JSON-RPC endpoint queried by viem. Override per chain.
VITE_RPCENDPOINT=https://ethereum-rpc.publicnode.com

# Base path used by the in-app API surface; injected into /config.js.
VITE_BASE_URL=/api/

# ---------------------------------------------------------------------------
# Container / cluster (mirrored in k8s manifests + Caddyfile; change together)
# ---------------------------------------------------------------------------

# Port Caddy listens on inside the container. Changing it requires updating:
#   - caddy/Caddyfile        `:{$PORT}` listen
#   - Dockerfile.prod        `EXPOSE`
#   - k8s/cm.yaml            `PORT`
#   - k8s/deployment.yaml    `containerPort` + probes
#   - k8s/service.yaml       `port` / `targetPort`
APP_INTERNAL_PORT=8080

# Host used by local healthchecks / smoke tests / the DAST target.
HEALTHCHECK_HOST=localhost

# Target of the Caddy `/publicnode` convenience redirect (Caddyfile reads it
# via `{$PUBLIC_RPC_URL:…}`; also set in k8s/cm.yaml).
PUBLIC_RPC_URL=https://ethereum-rpc.publicnode.com

# ---------------------------------------------------------------------------
# E2E
# ---------------------------------------------------------------------------

# RPC URL the Caddy `/publicnode` redirect points at (asserted by
# e2e/e2e-test.sh; must match the Caddyfile `redir` target).
EXPECTED_RPC=https://ethereum-rpc.publicnode.com

# ---------------------------------------------------------------------------
# Make timeouts / poll counts (mirror the Makefile `?=` defaults)
# ---------------------------------------------------------------------------
ROLLOUT_TIMEOUT=180s
LB_WAIT_SECONDS=60
LB_POLL_INTERVAL=1
HTTP_READY_RETRIES=15
SMOKE_TIMEOUT_SECONDS=30
